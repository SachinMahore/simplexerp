<!DOCTYPE html>
<html>
<head>
    <title>Job Card List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        body {
            background: #f5f5f5;
        }

        .card-box {
            background: #fff;
            padding: 15px;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>

    <div class="container mt-4">
        <div class="card-box">
            <a href="/JobCard/Create" class="btn btn-success mb-3">
                + New Job Card
            </a>
            <h3 class="mb-3">Job Card List</h3>

            <table class="table table-bordered table-striped text-center">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>PO No</th>
                        <th>Customer</th>
                        <th>Ref No</th>
                        <th>Order Qty</th>
                        <th>Bag Type</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="jobCardTable"></tbody>
            </table>

        </div>
    </div>

</body>
</html>

<script>
    $(document).ready(function () {
        loadJobCards();
    });

    function loadJobCards() {

        $.get('/JobCard/GetAllJobCards', function (res) {

            let html = "";

            $.each(res, function (i, v) {

                html += `
            <tr>
                <td>${v.JobCardId}</td>
                <td>${v.PurchaseNo || ''}</td>
                <td>${v.Customer || ''}</td>
                <td>${v.RefNo || ''}</td>
                <td>${v.OrderQty || 0}</td>
                <td>${v.BagType || ''}</td>

                <td>
                    <a href="/JobCard/Create?id=${v.JobCardId}"
                       class="btn btn-primary btn-sm">
                       Edit
                    </a>

                </td>
            </tr>`;
            });

            $("#jobCardTable").html(html);
        });
    }

    // DELETE (optional)
    function deleteJobCard(id) {

        if (!confirm("Are you sure to delete?")) return;

        $.post('/JobCard/Delete?id=' + id, function (res) {

            if (res.success) {
                alert("Deleted");
                loadJobCards();
            } else {
                alert(res.message);
            }
        });
    }
</script>