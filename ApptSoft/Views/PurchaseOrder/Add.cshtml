<!DOCTYPE html>
<html>
<head>
    <title>Purchase Order Entry</title>

    <!-- ✅ Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</head>

<body class="bg-light">

    <div class="container mt-4">

        <h3 class="text-primary mb-3">Purchase Order Entry</h3>

        <input type="hidden" id="PO_Id" />

        <div class="card shadow p-3 mb-4">
            <div class="row g-3">

                <!-- Date -->
                <div class="col-md-3">
                    <label class="form-label">Date</label>
                    <input type="date" id="Billing_Date" class="form-control" />
                </div>

                <!-- Customer Dropdown -->
                <div class="col-md-3">
                    <label class="form-label">Customer</label>
                    <select id="Customer" class="form-select">
                        <option value="">Select Customer</option>
                    </select>
                </div>

                <!-- Container -->
                <div class="col-md-3">
                    <label class="form-label">Container No</label>
                    <input id="Container_No" class="form-control" />
                </div>

                <!-- PO Number -->
                <div class="col-md-3">
                    <label class="form-label">PO Number</label>
                    <input id="PO_Number" class="form-control" />
                </div>

                <!-- Item -->
                <div class="col-md-3">
                    <label class="form-label">Item No</label>
                    <input id="Item_No" class="form-control" />
                </div>

                <!-- Bag Size -->
                <div class="col-md-3">
                    <label class="form-label">Bag Size</label>
                    <input id="Size_Of_Bag" class="form-control" />
                </div>

                <!-- Order Qty -->
                <div class="col-md-3">
                    <label class="form-label">Order Qty</label>
                    <input id="ORDER_QTY" class="form-control calc" />
                </div>

                <!-- Req Wt -->
                <div class="col-md-3">
                    <label class="form-label">Req Wt</label>
                    <input id="Req_Wt" class="form-control calc" />
                </div>

                <!-- Total Req Wt -->
                <div class="col-md-3">
                    <label class="form-label">Total Req Wt</label>
                    <input id="Total_Req_Wt" class="form-control" readonly />
                </div>
                <!-- Act Wt -->
                <div class="col-md-3">
                    <label class="form-label">Act Wt</label>
                    <input id="Act_Wt" class="form-control calc"  />
                </div>

                <!-- Total Act Wt -->
                <div class="col-md-3">
                    <label class="form-label">Total Act Wt</label>
                    <input id="Total_Act_Wt" class="form-control calc" readonly/>
                </div>
                <!-- Pcs Per Pallet -->
                <div class="col-md-3">
                    <label class="form-label">Pcs / Pallet</label>
                    <input id="PcsPerPallet" class="form-control" />
                </div>

                <!-- File -->
                <div class="col-md-3">
                    <label class="form-label">Attachment</label>
                    <input type="file" id="Attachment" class="form-control" />
                </div>

            </div>

            <div class="mt-3">
                <button id="savePO" class="btn btn-success">
                    Save / Update
                </button>
            </div>
        </div>

        <!-- ================= TABLE ================= -->
        <div class="card shadow p-3">
            <h5 class="text-secondary">Purchase Order List</h5>

            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>PO No</th>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Total Wt</th>
                            <th>Attachment</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="poTable"></tbody>
                </table>
            </div>
        </div>

    </div>

    <script>

        $(document).ready(function () {
            loadCustomers();
            loadPO();
        });


        // ================= LOAD CUSTOMER =================
        function loadCustomers() {

            $.get("/Company/GetCompanies", function (res) {

                let html = '<option value="">Select Customer</option>';

                $.each(res.model, function (i, v) {
                    html += `<option value="${v.Company_Name}">${v.Company_Name}</option>`;
                });

                $("#Customer").html(html);
            });
        }


        // ================= CALC =================
        $(document).on("keyup change", ".calc", function () {

            let qty = parseFloat($("#ORDER_QTY").val()) || 0;
            let reqWt = parseFloat($("#Req_Wt").val()) || 0;
            let wt = parseFloat($("#Act_Wt").val()) || 0;
            let totalReq = qty * reqWt;

            $("#Total_Req_Wt").val(totalReq.toFixed(4));

            let totalWt = wt * qty;
            $("#Total_Act_Wt").val(totalWt.toFixed(4));
        });

        // ================= SAVE =================
        $("#savePO").click(function () {

            let formData = new FormData();

            formData.append("PO_Id", $("#PO_Id").val());
            formData.append("Billing_Date", $("#Billing_Date").val());
            formData.append("Customer", $("#Customer").val());
            formData.append("Container_No", $("#Container_No").val());

            formData.append("PO_Number", $("#PO_Number").val());
            formData.append("Item_No", $("#Item_No").val());
            formData.append("Size_Of_Bag", $("#Size_Of_Bag").val());
            formData.append("ORDER_QTY", $("#ORDER_QTY").val());

            formData.append("Req_Wt", $("#Req_Wt").val());
            formData.append("Total_Req_Wt", $("#Total_Req_Wt").val());

            formData.append("Act_Wt", $("#Act_Wt").val());
            formData.append("Total_Act_Wt", $("#Total_Act_Wt").val());

            formData.append("PcsPerPallet", $("#PcsPerPallet").val());

            let fileInput = $("#Attachment")[0];
            if (fileInput.files.length > 0) {
                formData.append("Attachment", fileInput.files[0]);
            }

            let url = $("#PO_Id").val() ? "/PurchaseOrder/Update" : "/PurchaseOrder/Save";

            $.ajax({
                url: url,
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,

                success: function (res) {
                    if (res.success) {
                        alert(res.message || "Saved Successfully");
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                }
            });
        });


        // ================= LOAD TABLE =================
        function loadPO() {

            $.get("/PurchaseOrder/GetAll", function (data) {

                let html = "";

                $.each(data, function (i, v) {

                    html += `<tr>
                    <td>${formatDate(v.Billing_Date)}</td>
                    <td>${v.Customer}</td>
                    <td>${v.PO_Number}</td>
                    <td>${v.Item_No}</td>
                    <td>${v.ORDER_QTY}</td>
                    <td>${v.Total_Act_Wt}</td>
                    <td>${
                        v.Attachment
                            ? `<a href="${v.Attachment}" target="_blank" class="btn btn-sm btn-info">Download</a>`
                            : `<span class="text-muted">No File</span>`
                    } </td>

                    <td>
                        <button class="btn btn-sm btn-warning" onclick="edit(${v.PO_Id})">Edit</button>
                        <button class="btn btn-sm btn-danger" onclick="deletePO(${v.PO_Id})">Delete</button>
                    </td>
                </tr>`;
                });

                $("#poTable").html(html);
            });
        }


        // ================= EDIT =================
        function edit(id) {

            $.get("/PurchaseOrder/GetById?id=" + id, function (res) {

                $("#PO_Id").val(res.PO_Id);
                $("#Billing_Date").val(formatDateInput(res.Billing_Date));

                $("#Customer").val(res.Customer);
                $("#Container_No").val(res.Container_No);

                $("#PO_Number").val(res.PO_Number);
                $("#Item_No").val(res.Item_No);
                $("#Size_Of_Bag").val(res.Size_Of_Bag);

                $("#ORDER_QTY").val(res.ORDER_QTY);
                $("#Req_Wt").val(res.Req_Wt);
                $("#Total_Req_Wt").val(res.Total_Req_Wt);

                $("#Act_Wt").val(res.Act_Wt);
                $("#Total_Act_Wt").val(res.Total_Act_Wt);

                $("#PcsPerPallet").val(res.PcsPerPallet);
            });
        }


        // ================= DELETE =================
        function deletePO(id) {
            if (!confirm("Delete record?")) return;
            $.post("/PurchaseOrder/Delete", { id: id }, function () {
                loadPO();
            });
        }


        // ================= DATE =================
        function formatDate(date) {
            let d = new Date(parseInt(date.replace(/\/Date\((\d+)\)\//, "$1")));
            return d.toLocaleDateString();
        }

        function formatDateInput(date) {
            let d = new Date(parseInt(date.replace(/\/Date\((\d+)\)\//, "$1")));
            return d.toISOString().split('T')[0];
        }

    </script>

</body>
</html>